APP_NAME=Rhapsody
ENVIRONMENT=development
DEPLOYMENT_MODE=cloud
API_BASE_URL=http://localhost:8000

# Local Docker Compose defaults
DATABASE_URL=postgresql+asyncpg://rhapsody:rhapsody@postgres:5432/rhapsody
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=rhapsody

# Local development auth/secrets. Replace before any shared environment.
SERVICE_API_KEYS=local-dev-key
ENCRYPTION_KEY=replace-with-fernet-key
JWT_SIGNING_KEY=replace-with-jwt-signing-key
JWT_ISSUER=rhapsody
JWT_AUDIENCE=rhapsody-api

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# AI provider. For the current demo path, Gemini is the recommended simple mode.
AI_MODE=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
LOCAL_LLM_BASE_URL=http://ollama:11434

# Vision
VISION_MODE=gemini

# Speech-to-text
STT_MODE=local_whisper
LOCAL_WHISPER_MODEL=small
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8
LOCAL_WHISPER_LANGUAGE=ru

# Live-call listener is separate from the core Telegram bot flow.
LISTENER_ENABLED=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_USER_SESSION=
LISTENER_STORAGE_DIR=/tmp/rhapsody-listener
LIVE_TRANSCRIPTION_CHUNK_SECONDS=30

# Misc
SENTRY_DSN=
RATE_LIMIT_PER_MINUTE=120
LOG_LEVEL=INFO
