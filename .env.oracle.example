APP_NAME=Rhapsody
ENVIRONMENT=production
DEPLOYMENT_MODE=cloud
API_BASE_URL=https://api.rhapsody.example.com
RHAPSODY_DOMAIN=api.rhapsody.example.com

POSTGRES_PASSWORD=replace-with-long-random-password
DATABASE_URL=postgresql+asyncpg://rhapsody:replace-with-long-random-password@postgres:5432/rhapsody
REDIS_URL=redis://redis:6379/0

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=rhapsody
S3_SECRET_ACCESS_KEY=replace-with-long-random-password
S3_BUCKET=rhapsody

SERVICE_API_KEYS=replace-with-long-random-service-key
ENCRYPTION_KEY=replace-with-fernet-key
JWT_SIGNING_KEY=replace-with-long-random-jwt-key
JWT_ISSUER=rhapsody
JWT_AUDIENCE=rhapsody-api

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

AI_MODE=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
VISION_MODE=gemini

STT_MODE=local_whisper
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8
LOCAL_WHISPER_LANGUAGE=ru

LISTENER_ENABLED=true
RHAPSODY_TELEGRAM_API_ID=
RHAPSODY_TELEGRAM_API_HASH=
LISTENER_STORAGE_DIR=/var/lib/rhapsody/listener
LIVE_TRANSCRIPTION_CHUNK_SECONDS=30
LIVE_NO_AUDIO_TIMEOUT_SECONDS=15

SENTRY_DSN=
RATE_LIMIT_PER_MINUTE=120
LOG_LEVEL=INFO
